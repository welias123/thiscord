# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
SESSION_SECRET=change-me-to-a-long-random-string

# The public URL of this app (used as OAuth callback base).
# For local dev: http://localhost:8080
# For ngrok:     https://your-ngrok-url.ngrok-free.app
BASE_URL=http://localhost:8080

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://console.developers.google.com/
# 2. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Add Authorised redirect URI: BASE_URL/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/applications/new
# 2. Set Homepage URL to BASE_URL
# 3. Set Authorization callback URL to BASE_URL/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
